DATABASE_URL="postgresql://user:password@localhost:5432/tgmini?schema=public"
PORT=3000
# Comma-separated list of allowed origins. Leave empty to allow all (dev only).
CORS_ORIGINS="http://localhost:5173"

# Public backend URL used to resolve legacy local uploads.
BACKEND_URL="http://localhost:3000"

# Telegram Mini App auth.
TELEGRAM_BOT_TOKEN=""
ADMIN_TELEGRAM_IDS=""
TELEGRAM_AUTH_DISABLED="false"
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Cloudinary image uploads. You can use CLOUDINARY_URL instead of the three fields.
CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="zov/products"

# Optional order/admin notifications.
ORDER_NOTIFY_CHAT_ID=""
ADMIN_TELEGRAM_CHAT_ID=""
